    storage.set(`achievements:${u}`, []);
    storage.set(`photos:${u}`, []);
  });

  storage.set('_seeded', true);
}

// ─── HELPERS ───────────────────────────────────────────────────────────────────
function getToday() { return new Date().toISOString().split('T')[0]; }

function calculateStreak(username) {
  let streak = 0;
  const today = new Date();
  for (let i = 0; i < 365; i++) {
    const d = new Date(today); d.setDate(d.getDate() - i);
    const key = `log:${username}:${d.toISOString().split('T')[0]}`;
    const log = storage.get(key);
    if (log?.completed) streak++; else break;
  }
  return streak;
}

function getTotalSessions(username) {
  let count = 0;
  const today = new Date();
  for (let i = 0; i < 365; i++) {
    const d = new Date(today); d.setDate(d.getDate() - i);
    const log = storage.get(`log:${username}:${d.toISOString().split('T')[0]}`);
    if (log?.completed) count++;
  }
  return count;
}

function getWeekSessions(username) {
  let count = 0;
  for (let i = 0; i < 7; i++) {
    const d = new Date(); d.setDate(d.getDate() - i);
    const log = storage.get(`log:${username}:${d.toISOString().split('T')[0]}`);
    if (log?.completed) count++;
  }
  return count;
}

function getLastActivity(username) {
  for (let i = 0; i < 30; i++) {
    const d = new Date(); d.setDate(d.getDate() - i);
    const log = storage.get(`log:${username}:${d.toISOString().split('T')[0]}`);
    if (log?.completed) return i;
  }
  return 30;
}

function checkAndUnlockAchievements(username) {
  const current = storage.get(`achievements:${username}`) || [];
  const newOnes = [];
  const streak = calculateStreak(username);
  const sessions = getTotalSessions(username);
  const photos = (storage.get(`photos:${username}`) || []).length;
  if (streak >= 7 && !current.includes('first_week')) newOnes.push('first_week');
  if (sessions >= 10 && !current.includes('ten_sessions')) newOnes.push('ten_sessions');
  if (photos >= 5 && !current.includes('five_photos')) newOnes.push('five_photos');
  if (streak >= 30 && !current.includes('thirty_days')) newOnes.push('thirty_days');
  if (newOnes.length > 0) storage.set(`achievements:${username}`, [...current, ...newOnes]);
  return newOnes;
}

