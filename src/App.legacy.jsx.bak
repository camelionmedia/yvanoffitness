  storage.set('routines:all', [routine]);
  ['alumno1', 'alumno2', 'alumno3'].forEach(u => {
    storage.set(`assignment:${u}`, 'routine_1');
  });

  const today = new Date();
  const weights = { alumno1: [82, 81.5, 81, 80.2, 79.8], alumno2: [65, 64.5, 64, 63.7, 63.2], alumno3: [78, 77.5, 77, 76.5, 76] };
  ['alumno1', 'alumno2', 'alumno3'].forEach(u => {
    const measurements = weights[u].map((w, i) => {
      const d = new Date(today); d.setDate(d.getDate() - (4 - i) * 7);
      return { date: d.toISOString().split('T')[0], weight: w };
    });
    storage.set(`measurements:${u}`, measurements);

    const logs = {};
    for (let i = 6; i >= 0; i--) {
      const d = new Date(today); d.setDate(d.getDate() - i);
      const key = d.toISOString().split('T')[0];
      if (i % 2 === 0) logs[key] = { completed: true, points: 50, duration: Math.floor(Math.random() * 20) + 35, exercises: [] };
