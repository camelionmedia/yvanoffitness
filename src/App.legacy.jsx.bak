function seedData() {
  if (storage.get('_seeded')) return;
  const routine = {
    id: 'routine_1',
    name: 'Fuerza & Hipertrofia',
    description: 'Plan de 5 días enfocado en ganar masa muscular y fuerza funcional.',
    days: {
      'Lunes': [
        { id: 'e1', name: 'Sentadilla con barra', sets: 4, reps: '8-10', rest: 90, notes: 'Controlá la bajada en 3 segundos', video: 'https://youtube.com/watch?v=ultk9ucoQB4' },
        { id: 'e2', name: 'Prensa de piernas', sets: 3, reps: '12', rest: 60, notes: 'Full rango de movimiento' },
        { id: 'e3', name: 'Extensión de cuádriceps', sets: 3, reps: '15', rest: 45, notes: '' },
        { id: 'e4', name: 'Curl de isquiotibiales', sets: 3, reps: '12', rest: 45, notes: '' },
      ],
      'Martes': [
        { id: 'e5', name: 'Press banca plano', sets: 4, reps: '8', rest: 90, notes: 'Escápulas retraídas todo el tiempo', video: '' },
        { id: 'e6', name: 'Press inclinado mancuernas', sets: 3, reps: '10', rest: 75, notes: '' },
        { id: 'e7', name: 'Aperturas en cable', sets: 3, reps: '15', rest: 45, notes: 'Pecho, no brazos' },
        { id: 'e8', name: 'Fondos en paralelas', sets: 3, reps: '12', rest: 60, notes: '' },
      ],
      'Miércoles': [
        { id: 'e9', name: 'Dominadas', sets: 4, reps: '6-8', rest: 120, notes: 'Si no podés, usá banda elástica', video: '' },
        { id: 'e10', name: 'Remo en barra', sets: 4, reps: '8', rest: 90, notes: 'Codo pegado al cuerpo' },
        { id: 'e11', name: 'Jalón al pecho', sets: 3, reps: '12', rest: 60, notes: '' },
        { id: 'e12', name: 'Curl con barra', sets: 3, reps: '10', rest: 60, notes: '' },
      ],
      'Viernes': [
        { id: 'e13', name: 'Press militar', sets: 4, reps: '8', rest: 90, notes: 'Core activado, no arquear la espalda' },
        { id: 'e14', name: 'Elevaciones laterales', sets: 3, reps: '15', rest: 45, notes: 'Peso liviano, control total' },
        { id: 'e15', name: 'Pájaros en banco', sets: 3, reps: '12', rest: 45, notes: '' },
        { id: 'e16', name: 'Encogimientos de trapecio', sets: 3, reps: '15', rest: 30, notes: '' },
      ],
