        { id: 'e17', name: 'Peso muerto', sets: 4, reps: '6', rest: 120, notes: 'La técnica primero, el peso después', video: 'https://youtube.com/watch?v=1ZXobu7JvvE' },
        { id: 'e18', name: 'Hip thrust', sets: 3, reps: '12', rest: 75, notes: '' },
        { id: 'e19', name: 'Plancha', sets: 3, reps: '45s', rest: 30, notes: '' },
